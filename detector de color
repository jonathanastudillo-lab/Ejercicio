        "\n",
        "# Cargar la imagen\n",
        "image = cv2.imread(image_path)\n",
        "\n",
        "if image is None:\n",
        "    print(f\"Error: No se pudo cargar la imagen desde '{image_path}'.\")\n",
        "else:\n",
        "    # Convertir la imagen de BGR a RGB\n",
        "    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n",
        "\n",
        "    # Calcular el color promedio (B, G, R)\n",
        "    average_color_bgr = np.mean(image, axis=(0, 1))\n",
        "\n",
        "    # Convertir el color promedio a RGB\n",
        "    average_color_rgb = average_color_bgr[::-1]\n",
        "\n",
        "    print(f\"Análisis de: {os.path.basename(image_path)}\")\n",
        "    print(f\"Color promedio (RGB): {average_color_rgb.astype(int)}\")\n",
        "\n",
        "    # Mostrar la imagen\n",
        "    plt.imshow(image_rgb)\n",
