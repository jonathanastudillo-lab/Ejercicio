        "import cv2\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import os\n",
        "\n",
        "# La variable image_path ya fue definida en la celda de subida\n",
        "# como el nombre del archivo: 'Flujo_Trabajo_Taller.png'\n",
        "\n",
        "if 'image_path' not in locals():\n",
